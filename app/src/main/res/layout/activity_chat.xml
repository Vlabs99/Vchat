<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_screen">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_chat"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:elevation="5dp"
        android:paddingStart="4dp"
        android:paddingEnd="6dp"
        app:subtitle="VChat"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layout_pinned_banner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_surface_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_chat">

        <TextView
            android:id="@+id/tv_pinned_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/btn_unpin"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@android:color/transparent"
            android:contentDescription="Unpin message"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/text_secondary" />
    </LinearLayout>

    <EditText
        android:id="@+id/et_chat_search"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_input_dark"
        android:hint="Search in chat"
        android:imeOptions="actionSearch"
        android:maxLines="1"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_pinned_banner" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="6dp"
        android:paddingTop="6dp"
        android:paddingEnd="6dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/layout_attach_options"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/et_chat_search" />

    <ProgressBar
        android:id="@+id/progress_pagination"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginTop="8dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_chat_search" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_scroll_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="92dp"
        android:contentDescription="Scroll to bottom"
        android:src="@android:drawable/arrow_down_float"
        android:visibility="gone"
        app:backgroundTint="@color/colorAccent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/tv_unread_divider"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="148dp"
        android:background="@drawable/bg_chip_muted"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="Unread messages"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/layout_attach_options"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_attach_sheet"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/layout_chat_input"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
            <Button android:id="@+id/btn_opt_gallery" android:layout_width="0dp" android:layout_height="42dp" android:layout_margin="4dp" android:layout_weight="1" android:background="@drawable/bg_button_secondary" android:text="Gallery" android:textAllCaps="false" android:textColor="@color/text_primary" />
            <Button android:id="@+id/btn_opt_camera" android:layout_width="0dp" android:layout_height="42dp" android:layout_margin="4dp" android:layout_weight="1" android:background="@drawable/bg_button_secondary" android:text="Camera" android:textAllCaps="false" android:textColor="@color/text_primary" />
            <Button android:id="@+id/btn_opt_document" android:layout_width="0dp" android:layout_height="42dp" android:layout_margin="4dp" android:layout_weight="1" android:background="@drawable/bg_button_secondary" android:text="Document" android:textAllCaps="false" android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
            <Button android:id="@+id/btn_opt_audio" android:layout_width="0dp" android:layout_height="42dp" android:layout_margin="4dp" android:layout_weight="1" android:background="@drawable/bg_button_secondary" android:text="Audio" android:textAllCaps="false" android:textColor="@color/text_primary" />
            <Button android:id="@+id/btn_opt_contact" android:layout_width="0dp" android:layout_height="42dp" android:layout_margin="4dp" android:layout_weight="1" android:background="@drawable/bg_button_secondary" android:text="Contact" android:textAllCaps="false" android:textColor="@color/text_primary" />
            <Button android:id="@+id/btn_opt_poll" android:layout_width="0dp" android:layout_height="42dp" android:layout_margin="4dp" android:layout_weight="1" android:background="@drawable/bg_button_secondary" android:text="Poll" android:textAllCaps="false" android:textColor="@color/text_primary" />
        </LinearLayout>

        <Button android:id="@+id/btn_opt_event" android:layout_width="match_parent" android:layout_height="42dp" android:layout_marginTop="4dp" android:background="@drawable/bg_button_secondary" android:text="Event" android:textAllCaps="false" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_restriction_banner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_state_chip"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/layout_chat_input"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_restriction_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_restriction_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_chat_input"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#CC0F1820"
        android:gravity="bottom"
        android:orientation="vertical"
        android:elevation="8dp"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/layout_reply_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_chip_muted"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_replying_to"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <ImageButton
                android:id="@+id/btn_cancel_reply"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_sticker"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_button_secondary"
                android:contentDescription="Stickers"
                android:padding="10dp"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="@color/colorAccent" />

            <ImageButton
                android:id="@+id/btn_attach"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_button_secondary"
                android:contentDescription="Attach"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_add"
                app:tint="@color/text_primary" />

            <EditText
                android:id="@+id/et_message"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_dark"
                android:hint="Type a message"
                android:imeOptions="actionSend"
                android:maxLines="4"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

            <ImageButton
                android:id="@+id/btn_send"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_circle_accent"
                android:contentDescription="Send message"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/white" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
