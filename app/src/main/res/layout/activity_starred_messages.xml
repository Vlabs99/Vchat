<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen_dark">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_starred"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:title="Starred messages" />

    <EditText
        android:id="@+id/et_starred_search"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_margin="10dp"
        android:background="@drawable/bg_input_dark"
        android:hint="Search starred messages"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary" />

    <TextView
        android:id="@+id/tv_starred_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="No starred messages"
        android:textColor="@color/text_secondary"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_starred"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
