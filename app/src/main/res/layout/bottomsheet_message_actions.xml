<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp">

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layout_reaction_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView android:id="@+id/reaction_heart" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="H" android:textSize="24sp" />
            <TextView android:id="@+id/reaction_laugh" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="L" android:textSize="24sp" />
            <TextView android:id="@+id/reaction_like" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="U" android:textSize="24sp" />
            <TextView android:id="@+id/reaction_wow" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="W" android:textSize="24sp" />
            <TextView android:id="@+id/reaction_sad" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="S" android:textSize="24sp" />
            <TextView android:id="@+id/reaction_pray" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="P" android:textSize="24sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="8dp">
        <TextView android:id="@+id/action_reply" android:layout_width="match_parent" android:layout_height="46dp" android:background="?attr/selectableItemBackground" android:drawableStart="@android:drawable/ic_menu_revert" android:drawablePadding="10dp" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="10dp" android:text="Reply" android:textColor="@color/text_primary" />
        <TextView android:id="@+id/action_forward" android:layout_width="match_parent" android:layout_height="46dp" android:background="?attr/selectableItemBackground" android:drawableStart="@android:drawable/ic_menu_share" android:drawablePadding="10dp" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="10dp" android:text="Forward" android:textColor="@color/text_primary" />
        <TextView android:id="@+id/action_pin" android:layout_width="match_parent" android:layout_height="46dp" android:background="?attr/selectableItemBackground" android:drawableStart="@android:drawable/ic_menu_save" android:drawablePadding="10dp" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="10dp" android:text="Pin" android:textColor="@color/text_primary" />
        <TextView android:id="@+id/action_copy" android:layout_width="match_parent" android:layout_height="46dp" android:background="?attr/selectableItemBackground" android:drawableStart="@android:drawable/ic_menu_edit" android:drawablePadding="10dp" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="10dp" android:text="Copy" android:textColor="@color/text_primary" />
        <TextView android:id="@+id/action_star" android:layout_width="match_parent" android:layout_height="46dp" android:background="?attr/selectableItemBackground" android:drawableStart="@android:drawable/btn_star_big_off" android:drawablePadding="10dp" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="10dp" android:text="Star message" android:textColor="@color/text_primary" />
        <TextView android:id="@+id/action_info" android:layout_width="match_parent" android:layout_height="46dp" android:background="?attr/selectableItemBackground" android:drawableStart="@android:drawable/ic_menu_info_details" android:drawablePadding="10dp" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="10dp" android:text="Message info" android:textColor="@color/text_primary" />
        <TextView android:id="@+id/action_multi_select" android:layout_width="match_parent" android:layout_height="46dp" android:background="?attr/selectableItemBackground" android:drawableStart="@android:drawable/ic_menu_agenda" android:drawablePadding="10dp" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="10dp" android:text="Select messages" android:textColor="@color/text_primary" />
        <TextView android:id="@+id/action_delete_for_me" android:layout_width="match_parent" android:layout_height="46dp" android:background="?attr/selectableItemBackground" android:drawableStart="@android:drawable/ic_menu_delete" android:drawablePadding="10dp" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="10dp" android:text="Delete for me" android:textColor="@color/text_primary" />
        <TextView android:id="@+id/action_delete" android:layout_width="match_parent" android:layout_height="46dp" android:background="?attr/selectableItemBackground" android:drawableStart="@android:drawable/ic_menu_close_clear_cancel" android:drawablePadding="10dp" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="10dp" android:text="Delete for everyone" android:textColor="@color/error_red" />
    </LinearLayout>

</LinearLayout>
